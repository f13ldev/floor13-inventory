# Copy this file to .env.local for local development
# .env.local is gitignored and should never be committed

# App
NODE_ENV=development

# Database (Neon PostgreSQL)
# DATABASE_URL: pooled connection string — use for app queries (pgBouncer)
# DIRECT_URL:   direct connection string — used only by Prisma migrations
# Get both from your Neon project dashboard: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
